    {
        "id": "0ee9d34635385ba4",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "function 2",
        "func": "let parts = msg.topic.split(\"/\");\n\nif (parts.length < 3) return null;\n\nlet data;\nlet value;   // ✅ IMPORTANT\n\n// parsing intelligent\nif (typeof msg.payload === \"string\") {\n    try {\n        data = JSON.parse(msg.payload);\n    } catch (e) {\n        return null;\n    }\n} else {\n    data = msg.payload;\n}\n\n// ignore timestamps\nif (data.tag === \"time\") return null;\n\n// extraction\nlet machine = data.plc || parts[1];\nlet sensor = data.tag || parts[2];\n\n// nettoyage industriel\nlet raw = data.value;\n\n// cas 1 → number\nif (typeof raw === \"number\") {\n    value = raw;\n}\n\n// cas 2 → string\nelse if (typeof raw === \"string\") {\n    raw = raw.replace(\",\", \".\").trim();\n    value = Number(raw);\n}\n\n// fallback\nelse {\n    value = Number(raw);\n}\n\nif (isNaN(value)) {\n    node.warn(\"Invalid numeric value: \" + JSON.stringify(data));\n    return null;\n}\n\n// measurement\nmsg.measurement = machine + \"_\" + sensor;\n\n// payload influx\nmsg.payload = {\n    value: value\n};\n\nmsg.timestamp = data.timestamp;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 820,
        "y": 520,
        "wires": [
            [
                "21c077ef45fbc6f2",
                "35b646e2f4c3a4bb"
            ]
        ]
    },

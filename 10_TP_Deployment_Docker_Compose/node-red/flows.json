    {
        "id": "edba7a7a5fdbbfdd",
        "type": "mqtt in",
        "z": "f6f2187d.f17ca8",
        "name": "",
        "topic": "factory/+/#",
        "qos": "2",
        "datatype": "auto-detect",
        "broker": "2a1df8fd93b08537",
        "nl": false,
        "rap": true,
        "rh": 0,

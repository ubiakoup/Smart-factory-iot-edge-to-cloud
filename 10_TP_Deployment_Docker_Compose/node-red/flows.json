        "func": "let parts = msg.topic.split(\"/\");\n\n// sécurité\nif (parts.length < 3) return null;\n\nlet machine = parts[1];\nlet sensor = parts[2];\n\nlet value = Number(msg.payload);\n\n// ignorer non numérique\nif (isNaN(value)) return null;\n\n// format SIMPLE (compatible mode 1)\nmsg.payload = {};\nmsg.payload[sensor] = value;\n\n// ajouter tag\nmsg.tags = {\n    machine: machine\n};\n\nreturn msg;",
